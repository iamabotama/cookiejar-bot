# CookieJar Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to GitHub.

# -------------------------------------------------------
# REQUIRED
# -------------------------------------------------------

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_botfather_token_here

# Your bot's Telegram username (without the @ symbol)
TELEGRAM_BOT_USERNAME=CookieJarBot

# xAI Grok API key (from https://console.x.ai/)
GROK_API_KEY=your_grok_api_key_here

# GitHub personal access token (needs repo read/write scope)
GITHUB_TOKEN=your_github_token_here

# GitHub repo where knowledge files are stored
GITHUB_REPO=iamabotama/cookiejar-bot

# Comma-separated Telegram user IDs with admin access
ADMIN_USER_IDS=123456789,987654321

# -------------------------------------------------------
# OPTIONAL (defaults shown)
# -------------------------------------------------------

# Bot operating mode: 'primary' (Q&A) or 'listener' (silent capture)
BOT_MODE=primary

# GitHub branch for knowledge files
GITHUB_BRANCH=main

# How often (in seconds) to sync cache from GitHub (default: 30 min)
CACHE_SYNC_INTERVAL=1800

# Days before an entry is auto-flagged as stale (default: 90 days)
STALE_AFTER_DAYS=90

# AI model to use for standard queries
AI_MODEL=grok-3-mini

# AI model to use for complex/long queries
AI_MODEL_HEAVY=grok-3

# xAI API base URL (change only if using a different provider)
AI_BASE_URL=https://api.x.ai/v1
